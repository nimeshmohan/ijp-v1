# Webflow Data API
# Personal Access Token / Site Token scoped to CMS read/write on this site only.
WEBFLOW_API_TOKEN=
WEBFLOW_SITE_ID=
# Fixed — this app only ever touches this one collection.
WEBFLOW_COLLECTION_ID=6a533add938a981683bbfe8b

# Firebase Admin SDK (from a service account JSON — never commit the JSON file itself)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the \n escape sequences literal; the app converts them to real newlines at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Used to sign short-lived internal artifacts (not used for Firebase session verification itself)
JWT_SECRET=

# Server
PORT=4000
NODE_ENV=development

# Origin allowed to call this API (the deployed client URL in production)
CLIENT_ORIGIN=http://localhost:5173
