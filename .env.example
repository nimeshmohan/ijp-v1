# ============================================================
# IJP HR CMS Manager — Environment Variable Reference
# ============================================================
# This root file is documentation only. The application does NOT
# read a root .env file. Each workspace loads its own .env:
#
#   server/.env   -> backend (Express, Firebase Admin, Webflow)
#   client/.env   -> frontend (Vite, Firebase client SDK)
#
# Copy server/.env.example -> server/.env
# Copy client/.env.example -> client/.env
# and fill in real values. Never commit either .env file.
# ============================================================

# ---------- Backend (server/.env) ----------
WEBFLOW_API_TOKEN=
WEBFLOW_SITE_ID=
WEBFLOW_COLLECTION_ID=6a533add938a981683bbfe8b
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
JWT_SECRET=
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# ---------- Frontend (client/.env) ----------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_API_BASE_URL=http://localhost:4000
